# ESP32 uses this token in: Authorization: Bearer <token>
# Leave empty only for temporary local debugging. Set it on Vercel for real use.
SMARTPET_API_TOKEN=change-me-device-token

# Browser dashboard password.
SMARTPET_ADMIN_PASSWORD=change-me-admin-password

# Default device id shown in the dashboard.
NEXT_PUBLIC_DEFAULT_DEVICE=smartpet-01
SMARTPET_DEFAULT_DEVICE=smartpet-01

# Upstash Redis REST credentials. Required for persistent storage on Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# If a command has been delivered but no ack is received, allow re-delivery after this time.
SMARTPET_COMMAND_REDELIVER_MS=10000
